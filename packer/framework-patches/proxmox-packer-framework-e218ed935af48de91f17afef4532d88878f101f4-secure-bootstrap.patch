index 4fb6f22..f39253a 100644
--- a/packer/variables.pkr.hcl
+++ b/packer/variables.pkr.hcl
@@ -50,9 +50,22 @@ variable "deploy_user_password" {
 }

 variable "deploy_user_public_key" {
   type        = string
+  default     = null
+  description = "Legacy SSH public-key input kept for compatibility with older consumers."
+  sensitive   = true
+}
+
+variable "deploy_user_password_hash" {
+  type        = string
+  description = "The SHA-512 crypt password hash for the deploy user at install time."
+  sensitive   = true
+}
+
+variable "deploy_user_key" {
+  type        = string
   description = "The SSH public key to log in to the guest operating system."
   sensitive   = true
 }

 #endregion --- [ Deploy User ] --------------------------------------------------------------- #
