{
  "version": "2.0.0",
  "tasks": [
    //region ------ [ Framework Validation ] -------------------------------- #
    {
      "label": "Framework: Verify Sibling Checkouts",
      "type": "shell",
      "command": "if (!(Test-Path \"${workspaceFolder}/../proxmox-packer-framework/packer\")) { throw \"Missing ../proxmox-packer-framework/packer\" }; if (!(Test-Path \"${workspaceFolder}/../ansible-framework/ansible.cfg\")) { throw \"Missing ../ansible-framework/ansible.cfg\" }",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Sync Consumer Files (Framework Workspace)",
      "type": "shell",
      "command": "Copy-Item -Force \"${workspaceFolder}/packer/systems.auto.pkrvars.hcl\" \"${workspaceFolder}/../proxmox-packer-framework/packer/\"; Copy-Item -Force \"${workspaceFolder}/packer/ks.pkrtpl.hcl\" \"${workspaceFolder}/../proxmox-packer-framework/packer/\"; Copy-Item -Force \"${workspaceFolder}/packer/rocky-linux-9.yml\" \"${workspaceFolder}/../proxmox-packer-framework/packer/\"",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Format (Repo Workspace)",
      "type": "shell",
      "command": "packer fmt -diff packer",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Format Check (Repo Workspace)",
      "type": "shell",
      "command": "packer fmt -check -diff packer",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Init (Framework Workspace)",
      "type": "shell",
      "command": "packer init .",
      "options": {
        "cwd": "${workspaceFolder}/../proxmox-packer-framework/packer"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Ansible: Syntax Check (Framework Workspace)",
      "type": "shell",
      "command": "$env:ANSIBLE_CONFIG = \"${workspaceFolder}/../ansible-framework/ansible.cfg\"; ansible-playbook --syntax-check -i localhost, -c local \"${workspaceFolder}/../proxmox-packer-framework/packer/rocky-linux-9.yml\"",
      "options": {
        "cwd": "${workspaceFolder}/../proxmox-packer-framework/packer"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Validate (Framework Workspace)",
      "type": "shell",
      "command": "packer validate .",
      "options": {
        "cwd": "${workspaceFolder}/../proxmox-packer-framework/packer"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Packer: Build (Framework Workspace, Owner Defaults)",
      "type": "shell",
      "command": "packer build -force -timestamp-ui -color=false -on-error=cleanup .",
      "options": {
        "cwd": "${workspaceFolder}/../proxmox-packer-framework/packer"
      },
      "group": "build",
      "problemMatcher": []
    },
    //endregion --- [ Framework Validation ] -------------------------------- #

    //region ------ [ Linting & Security ] --------------------------------- #
    {
      "label": "YAML Lint",
      "type": "shell",
      "command": "yamllint -c .config/.yamllint.yaml .",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Markdown Lint",
      "type": "shell",
      "command": "markdownlint --config .config/.markdownlint.json '**/*.md'",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Trivy: Security Scan",
      "type": "shell",
      "command": "trivy config --severity HIGH,CRITICAL .",
      "group": "test",
      "problemMatcher": []
    },
    //endregion --- [ Linting & Security ] --------------------------------- #

    //region ------ [ Pre-Commit ] ----------------------------------------- #
    {
      "label": "Pre-Commit: Run All",
      "type": "shell",
      "command": "pre-commit run --all-files",
      "group": "test",
      "problemMatcher": []
    },
    //endregion --- [ Pre-Commit ] ----------------------------------------- #

    //region ------ [ Composite ] ------------------------------------------ #
    {
      "label": "Full Validation (Requires sibling frameworks)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Framework: Verify Sibling Checkouts",
        "Packer: Format Check (Repo Workspace)",
        "Packer: Sync Consumer Files (Framework Workspace)",
        "Packer: Init (Framework Workspace)",
        "Ansible: Syntax Check (Framework Workspace)",
        "Packer: Validate (Framework Workspace)",
        "YAML Lint",
        "Markdown Lint"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
    //endregion --- [ Composite ] ------------------------------------------ #
  ]
}
